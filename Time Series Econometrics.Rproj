  "fig_ma10.pdf         -- Raw series + 10-year centred moving average",
  "fig_acf_raw.pdf      -- ACF and PACF of raw lynx series",
  "fig_hw.pdf           -- Holt-Winters fit and 12-year benchmark forecast",
  "fig_log_series.pdf   -- Log-transformed series (variance stabilised)",
  "fig_log_trend.pdf    -- Log series with OLS trend line",
  "fig_trend_resid.pdf  -- OLS residuals and residual ACF",
  "fig_gls_residuals.pdf-- OLS vs GLS normalised residuals comparison",
  "fig_diff_log.pdf     -- First-differenced log series with mean annotated",
  "fig_acf_diff.pdf     -- ACF and PACF after transformation",
  "fig_arma21_resid.pdf -- ARMA(2,1) residual ACF and PACF",
  "fig_arima_resid_compare.pdf -- ARIMA(2,1,0) vs ARIMA(2,1,1) diagnostics",
  "fig_arma21_forecast.pdf -- 12-year forecast with 95% PI"
)
cat(paste(figs, collapse = "\n"), "\n")
cat("\n=== ANALYSIS COMPLETE ===\n")
